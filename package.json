{
  "name": "vue-3dtiles-viewer",
  "version": "1.0.1",
  "description": "3D Tiles viewer component for Vue2 and Vue3",
  "main": "dist/core/index.cjs.js",
  "module": "dist/core/index.esm.js",
  "exports": {
    "./core": {
      "import": "./dist/core/index.esm.js",
      "require": "./dist/core/index.cjs.js"
    },
    "./vue2": {
      "import": "./dist/vue2/index.esm.js",
      "require": "./dist/vue2/TilesViewer.common.js"
    },
    "./vue3": {
      "import": "./dist/vue3/index.mjs",
      "require": "./dist/vue3/index.js"
    },
    "./src/*": "./src/*"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:core": "rollup -c rollup.config.js",
    "build:vue2": "vue-cli-service build --target lib --dest dist/vue2 --name TilesViewer src/vue2/index.js && rollup -c rollup.vue2.config.js",
    "build:vue3": "vite build",
    "build": "npm run build:core && npm run build:vue2 && npm run build:vue3"
  },
  "peerDependencies": {
    "3d-tiles-renderer": ">=0.3.0",
    "three": ">=0.158.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/cli-service": "^5.0.8",
    "rollup": "^3.29.5",
    "three": "^0.167.1",
    "vite": "^4.5.3",
    "vue": "^3.4.38",
    "vue-template-compiler": "^2.7.16",
    "webpack": "^5.95.0"
  },
  "keywords": [
    "3d-tiles",
    "cesium",
    "three",
    "threejs",
    "vue",
    "vue2",
    "vue3",
    "bim",
    "gis"
  ],
  "author": "",
  "license": "MIT"
}
